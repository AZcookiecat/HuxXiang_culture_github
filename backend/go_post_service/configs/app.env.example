GO_POST_SERVICE_NAME=go-post-service
GO_POST_SERVICE_ENV=dev
GO_POST_SERVICE_ADDR=:8080

DATABASE_URL=root:password@tcp(127.0.0.1:3306)/huxiang?charset=utf8mb4
READ_DATABASE_URL=
JWT_SECRET_KEY=change-me

POST_CACHE_TTL=15s
POST_SERVICE_READ_TIMEOUT=3s
POST_SERVICE_WRITE_TIMEOUT=5s

POST_DB_MAX_OPEN_CONNS=128
POST_DB_MAX_IDLE_CONNS=32
POST_DB_CONN_MAX_LIFETIME=30m

POST_RATE_LIMIT_RPS=300
POST_RATE_LIMIT_BURST=600

POST_CORS_ALLOW_ORIGINS=*
POST_ENABLE_HTTPS_REDIRECT=false
POST_LOG_JSON=false
